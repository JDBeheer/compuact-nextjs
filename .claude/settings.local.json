{
  "permissions": {
    "allow": [
      "Bash(npx next:*)",
      "Bash(git push:*)",
      "Bash(gh auth:*)",
      "Bash(git remote:*)",
      "Bash(git commit -m 'Replace hardcoded reviews with Google Places API integration:*)",
      "WebFetch(domain:maps.googleapis.com)",
      "Bash(git commit:*)",
      "Bash(ls:*)",
      "Bash(grep -r \"SUPABASE\" /Users/eriklindeman/GitHub/compuact-nextjs/.env*)",
      "Bash(grep -r \"supabase\" /Users/eriklindeman/GitHub/compuact-nextjs/.env*)",
      "Bash(curl:*)",
      "Bash(echo \"Exit: $?\")",
      "Bash(python3 -m json.tool)",
      "WebFetch(domain:www.computertraining.nl)",
      "Bash(npx tsx:*)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; cd \"$(git -C \"$(dirname \"$f\")\" rev-parse --show-toplevel)\" && git add -A && git diff --cached --quiet && exit 0; git commit -m \"Auto-commit: update $(basename \"$f\")\" && git push; } 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Committing and pushing..."
          }
        ]
      }
    ]
  }
}
